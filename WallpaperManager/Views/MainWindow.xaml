<Window x:Class="WallpaperManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wallpaper Manager"
        Height="500"
        Width="700"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Менеджер обоев"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#333333"/>
            <TextBlock Text="{Binding CurrentSourceName}"
                       FontSize="14"
                       Foreground="#666666"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Preview -->
        <Border Grid.Row="1"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Background="#F5F5F5">
            <Grid>
                <TextBlock Text="Нет изображения"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#999999"
                           FontSize="16"
                           Visibility="{Binding CurrentWallpaperImage, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>

                <Image Source="{Binding CurrentWallpaperImage}"
                       Stretch="Uniform"
                       Margin="8"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
        </Border>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Сменить сейчас"
                            Command="{Binding ChangeNowCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"/>

                    <Button Command="{Binding ToggleAutoChangeCommand}"
                            MinWidth="120">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Content" Value="Стоп"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutoChangeEnabled}" Value="False">
                                        <Setter Property="Content" Value="Старт"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Настройки"
                        Command="{Binding ShowSettingsCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </Grid>
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12,8"
                Background="#F8F8F8"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#666666"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding TimerIntervalText}"
                           VerticalAlignment="Center"
                           Foreground="#888888"
                           Margin="16,0"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding CacheSizeText}"
                           VerticalAlignment="Center"
                           Foreground="#888888"/>
            </Grid>
        </Border>
    </Grid>
</Window>
